# Role build artifacts (gen/ and dist/ are build intermediates)
.exomonad/roles/*/gen/
.exo/roles/*/gen/
.exomonad/roles/*/dist/
.exo/roles/*/dist/
# Per-worktree MCP config (auto-generated at spawn time)
.mcp.json

rust/.exomonad/
rust/.exo/
rust/exomonad/.exomonad/
rust/exomonad/.exo/

# GHC TemplateHaskell splice .so dumps (leaked to CWD)
.*-[0-9]*.so

# Stale Nix shell tempdirs (leak to CWD when shell is killed hard)
nix-develop-*/
nix-shell.*/

# Temporary task files for worktree dispatch
*.md.tmp
# Prompt temp files (created by spawn, read by agents via $(cat ...))
.exo/tmp/

# Cargo build artifacts (workspace and per-crate)
**/target/

# Interagent communication artifacts (TL↔Codex design docs)
interagent/

# Integration test build artifacts
tests/integration/external-consumer/result
tests/integration/external-consumer/.exomonad/wasm/
tests/integration/external-consumer/.exo/wasm/

# Symlinked proto directory for Rust (deduplicated to root proto/)

# Jujutsu state
.jj/
.gemini/settings.json

# Local lolearn database
.lolearn/knowledge.db

# Generated symlinks (provisioned by init/spawn, source in .exo/roles/)
.claude/rules/exomonad_*.md

# try-exomonad/ pre-built artifacts (staged by run.sh from host)
try-exomonad/artifacts/

# Vendored NotebookLM MCP (build artifacts and secrets)
vendor/notebooklm-mcp/node_modules/
vendor/notebooklm-mcp/dist/
vendor/notebooklm-mcp/.env
vendor/notebooklm-mcp/.exo/

# SQLite sidecar files
*.db-shm
*.db-wal

# Chainlink local issue database (generated by chainlink CLI)
.chainlink/
.chainlink/issues.db

# Local exo runtime state
.exo/prs.json

# Working notes (not committed)
archive/
notes-knot-atproto-push.md
opencode-*.md
